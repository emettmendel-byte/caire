# CAIRE environment configuration
# Copy to .env and set values. Do not commit .env to version control.

# -----------------------------------------------------------------------------
# LLM (required for compilation)
# -----------------------------------------------------------------------------
# Default: Ollama (local). Ensure Ollama is running and pull the model: ollama run deepseek-r1:latest
OLLAMA_HOST=http://localhost:11434

# Provider: "ollama" | "openai" | "anthropic" | "gemini"
CAIRE_LLM_PROVIDER=ollama

# Model name (default for Ollama: deepseek-r1:latest)
# CAIRE_LLM_MODEL=deepseek-r1:latest

# Cloud providers (only if you set CAIRE_LLM_PROVIDER to one of these):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY= or GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite file path. Default: project root / caire.db
CAIRE_DB_PATH=./caire.db

# Set to 1 to log SQL queries (development only)
# CAIRE_DB_ECHO=0

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
# Port for uvicorn (default 8000)
# PORT=8000

# -----------------------------------------------------------------------------
# Authentication (Phase 1)
# -----------------------------------------------------------------------------
# If set, API requests must include X-API-Key or api_key query with this value.
# Leave empty for local development (no auth). Production: set a strong secret key (not your Gemini key).
CAIRE_API_KEY=

# Rate limit: max requests per window (0 = disabled)
CAIRE_RATE_LIMIT_REQUESTS=120
CAIRE_RATE_LIMIT_WINDOW_SEC=60

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Level: DEBUG, INFO, WARNING, ERROR
CAIRE_LOG_LEVEL=INFO

# Set to 1 to log full LLM prompts and responses (avoid in production with sensitive data)
CAIRE_LOG_LLM_CONTENT=0

# -----------------------------------------------------------------------------
# Development vs production
# -----------------------------------------------------------------------------
# Development: leave CAIRE_API_KEY empty, CAIRE_LOG_LEVEL=DEBUG if needed, run with --reload
# Production: set CAIRE_API_KEY, use CAIRE_LOG_LEVEL=INFO or WARNING, mount logs and DB on volumes
